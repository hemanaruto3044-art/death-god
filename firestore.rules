rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function getProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'displayUid', 'updatedAt'])
        && data.keys().size() <= 14 
        && data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 50
        && data.displayUid is string && data.displayUid.matches('^[0-9]{5}$')
        && (data.get('fcmToken', '') is string && data.get('fcmToken', '').size() <= 1024)
        && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 2048)
        && (data.get('peerId', '') is string && data.get('peerId', '').size() <= 256)
        && (data.get('blockedUids', []) is list)
        && data.updatedAt == request.time;
    }

    function isCallerBlocked(targetDisplayUid, callerDisplayUid) {
      let uidPath = /databases/$(database)/documents/uids/$(targetDisplayUid);
      let targetUserId = exists(uidPath) ? get(uidPath).data.ownerId : null;
      let targetProfile = (targetUserId != null && exists(/databases/$(database)/documents/users/$(targetUserId))) 
        ? get(/databases/$(database)/documents/users/$(targetUserId)).data : null;
      return targetProfile != null && callerDisplayUid in targetProfile.get('blockedUids', []);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'fcmToken', 'updatedAt', 'displayUid', 'status', 'isMuted', 'photoURL', 'blockedUids', 'peerId']);
      allow delete: if isOwner(userId);
    }

    match /uids/{displayUid} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create, update: if isSignedIn() && isValidId(displayUid) && incoming().displayUid == displayUid && incoming().ownerId == request.auth.uid;
      allow delete: if false;
    }

    match /calls/{displayUid} {
      function isValidCall(data) {
        return data.callerUid is string && data.callerName is string && data.channelName is string
          && (data.get('callerPeerId', '') is string && data.get('callerPeerId', '').size() <= 256);
      }
      allow get, update, delete: if isSignedIn() && (
        getProfile().displayUid == displayUid || 
        (resource != null && resource.data.callerUid == getProfile().displayUid)
      );
      allow create: if isSignedIn() 
        && incoming().callerUid == getProfile().displayUid
        && isValidCall(incoming())
        && !isCallerBlocked(displayUid, incoming().callerUid);
    }

    match /users/{userId}/history/{callId} {
      allow read, create: if isOwner(userId);
      allow update, delete: if false;
    }
  }
}
